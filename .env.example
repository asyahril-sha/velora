# =============================================================================
# VELORA - Environment Variables Example
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# REQUIRED - API KEYS
# =============================================================================

# Telegram Bot Token (dari @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# DeepSeek API Key (dari platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Admin ID (user ID Telegram Mas, dapatkan dari @userinfobot)
ADMIN_ID=123456789

# =============================================================================
# OPTIONAL - DATABASE
# =============================================================================

# Database type (sqlite)
DB_TYPE=sqlite

# Database path
DB_PATH=data/velora.db

# =============================================================================
# OPTIONAL - AI SETTINGS
# =============================================================================

# AI Temperature (0-2, default: 0.85)
AI_TEMPERATURE=0.85

# AI Max Tokens (default: 1200)
AI_MAX_TOKENS=1200

# AI Timeout in seconds (default: 45)
AI_TIMEOUT=45

# AI Model (default: deepseek-chat)
AI_MODEL=deepseek-chat

# =============================================================================
# OPTIONAL - WEBHOOK (untuk Railway deployment)
# =============================================================================

# Webhook path (default: /webhook)
WEBHOOK_PATH=/webhook

# Webhook secret token (optional, for security)
WEBHOOK_SECRET=your_secret_token_here

# Railway will set these automatically
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app
# RAILWAY_STATIC_URL=your-app.up.railway.app
# PORT=8080

# =============================================================================
# OPTIONAL - LOGGING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# JSON format logging (true/false)
LOG_JSON_FORMAT=true

# =============================================================================
# OPTIONAL - FEATURE TOGGLES
# =============================================================================

# Enable vulgar mode (true/false)
VULGAR_MODE_ENABLED=true

# Enable aftercare (true/false)
AFTERCARE_ENABLED=true

# Enable flashback (true/false)
FLASHBACK_ENABLED=true

# Enable proactive chat (true/false)
PROACTIVE_CHAT_ENABLED=true

# Enable auto backup (true/false)
AUTO_BACKUP_ENABLED=true

# =============================================================================
# OPTIONAL - WORLD SETTINGS
# =============================================================================

# Default drama level (0-100)
WORLD_DEFAULT_DRAMA_LEVEL=0

# Max drama level (0-100)
WORLD_MAX_DRAMA_LEVEL=100

# Drama decay per hour
WORLD_DRAMA_DECAY_PER_HOUR=2.0

# Enable cross-role effects
WORLD_CROSS_ROLE_EFFECT_ENABLED=true
