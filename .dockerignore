.pytest_cache/
.coverage
htmlcov/
.tox/

# Environment
.env
.env.local
.env.production
.env.development
*.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.vscode/
.idea/

# Database
*.db
*.sqlite
*.sqlite3
data/
data/backups/
data/memory/
*.db-journal
*.db-wal
*.db-shm

# Logs
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Git
.git/
.gitignore
.gitattributes

# Testing
tests/
test_*.py
*_test.py
.pytest_cache/
.coverage
htmlcov/

